{
  "name": "scaffoldx",
  "version": "1.0.0",
  "description": "Generate, export, and share project structures as portable JSON blueprints",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "scaffoldx": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "scaffold",
    "cli",
    "boilerplate",
    "project-structure",
    "generator",
    "typescript",
    "blueprint"
  ],
  "author": "Deviprasad Rai <dpraidola@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "node": "^26.4.0",
    "ora": "^9.4.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1"
  }
}
